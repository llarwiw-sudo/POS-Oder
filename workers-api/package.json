{
  "name": "restaurant-pos-api",
  "version": "1.0.0",
  "description": "Restaurant POS API for Cloudflare Workers",
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create restaurant-pos-db",
    "db:init": "wrangler d1 execute restaurant-pos-db --file=./schema.sql",
    "db:init:local": "wrangler d1 execute restaurant-pos-db --local --file=./schema.sql"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
