{
  "name": "warp-orders-api",
  "version": "1.0.0",
  "description": "Warp Orders API for Cloudflare Workers",
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create warp-orders-db",
    "db:init": "wrangler d1 execute warp-orders-db --file=./schema.sql",
    "db:init:local": "wrangler d1 execute warp-orders-db --local --file=./schema.sql"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
